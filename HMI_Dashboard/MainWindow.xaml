<Window x:Class="HMI_Dashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="機台監控系統" Height="600" Width="900"
        Background="#1E1E2E">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="150"/>
        </Grid.RowDefinitions>

        <!-- 頂部控制列 -->
        <Grid Grid.Row="0" Background="#2A2A3E" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="產線設備監控系統" 
                       Foreground="White" FontSize="20" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="15,0"/>

            <!-- 狀態燈 -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" 
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                <Ellipse x:Name="StatusLight" Width="20" Height="20" Fill="Gray"/>
                <TextBlock x:Name="StatusText" Text="待機" Foreground="White" 
                           Margin="8,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <Button Grid.Column="2" x:Name="BtnStart" Content="▶ 啟動" 
                    Background="#27AE60" Foreground="White" 
                    FontSize="14" Margin="5" Click="BtnStart_Click"/>

            <Button Grid.Column="3" x:Name="BtnStop" Content="■ 停止" 
                    Background="#E74C3C" Foreground="White" 
                    FontSize="14" Margin="5" Click="BtnStop_Click"/>
            <Button Grid.Column="4" x:Name="BtnHistory" Content="📋 歷史" 
                    Background="#2980B9" Foreground="White" 
                    FontSize="14" Margin="5" Click="BtnHistory_Click"/> 
        </Grid>

        <!-- 中間主體 -->
        <Grid Grid.Row="1" Margin="0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>

            <!-- 圖表 -->
            <lvc:CartesianChart Grid.Column="0" x:Name="TempChart"
                                Series="{Binding Series}"
                                XAxes="{Binding XAxes}"
                                YAxes="{Binding YAxes}"
                                Background="#2A2A3E"/>

            <!-- 右側數值面板 -->
            <StackPanel Grid.Column="1" Margin="10,0,0,0" Background="#2A2A3E">
                <TextBlock Text="即時數值" Foreground="#AAA" 
                           FontSize="13" Margin="10,10,0,5"/>

                <TextBlock Text="溫度 (°C)" Foreground="#AAA" Margin="10,10,0,0"/>
                <TextBlock x:Name="TempValue" Text="--" Foreground="#E74C3C" 
                           FontSize="32" FontWeight="Bold" Margin="10,0"/>

                <TextBlock Text="壓力 (bar)" Foreground="#AAA" Margin="10,20,0,0"/>
                <TextBlock x:Name="PressureValue" Text="--" Foreground="#3498DB" 
                           FontSize="32" FontWeight="Bold" Margin="10,0"/>

                <Separator Background="#444" Margin="10,15"/>

                <TextBlock Text="溫度上限設定" Foreground="#AAA" Margin="10,5,0,0"/>
                <TextBox x:Name="TempLimitInput" Text="100" 
                         Background="#3A3A4E" Foreground="White"
                         FontSize="16" Margin="10,5" Padding="5"/>

                <Button x:Name="BtnSave" Content="💾 儲存配方" 
                        Background="#8E44AD" Foreground="White"
                        FontSize="13" Margin="10,5" Padding="8"
                        Click="BtnSave_Click"/>
            </StackPanel>
        </Grid>

        <!-- 底部 Log 區 -->
        <Grid Grid.Row="2" Background="#2A2A3E">
            <Grid.RowDefinitions>
                <RowDefinition Height="25"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="事件記錄" Foreground="#AAA" 
                       FontSize="12" Margin="10,3"/>
            <ListBox x:Name="LogList" Grid.Row="1"
                     Background="#1E1E2E" Foreground="#CCC"
                     FontSize="12" Margin="5,0,5,5"
                     BorderThickness="0"/>
        </Grid>
    </Grid>
</Window>