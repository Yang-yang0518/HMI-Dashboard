<Window x:Class="HMI_Dashboard.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="歷史事件查詢" Height="500" Width="800"
        Background="#1E1E2E">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- 查詢條件列 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="開始日期：" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <DatePicker x:Name="StartDate" Width="130" Margin="0,0,15,0"/>

            <TextBlock Text="結束日期：" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <DatePicker x:Name="EndDate" Width="130" Margin="0,0,15,0"/>

            <Button x:Name="BtnQuery" Content="🔍 查詢" 
                    Background="#27AE60" Foreground="White"
                    Padding="15,5" Margin="0,0,10,0"
                    Click="BtnQuery_Click"/>

            <Button x:Name="BtnExport" Content="📥 匯出 CSV" 
                    Background="#8E44AD" Foreground="White"
                    Padding="15,5"
                    Click="BtnExport_Click"/>
        </StackPanel>

        <!-- 資料表格 -->
        <DataGrid Grid.Row="1" x:Name="ResultGrid"
                  Background="#2A2A3E" Foreground="White"
                  RowBackground="#2A2A3E" AlternatingRowBackground="#33334A"
                  GridLinesVisibility="Horizontal" BorderThickness="0"
                  ColumnHeaderHeight="35" AutoGenerateColumns="False"
                  IsReadOnly="True" Margin="0,10">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#3A3A4E"/>
                    <Setter Property="Foreground" Value="#AAA"/>
                    <Setter Property="Padding" Value="10,0"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="編號" Binding="{Binding Id}" Width="60"/>
                <DataGridTextColumn Header="事件類型" Binding="{Binding EventType}" Width="100"/>
                <DataGridTextColumn Header="溫度數值 (°C)" Binding="{Binding Value}" Width="120"/>
                <DataGridTextColumn Header="發生時間" Binding="{Binding OccurredAt}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 底部統計 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock x:Name="SummaryText" 
                       Foreground="#AAA" FontSize="13"
                       Text="請選擇日期範圍後按查詢"/>
        </StackPanel>
    </Grid>
</Window>